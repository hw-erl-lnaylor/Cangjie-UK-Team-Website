---
import "../styles/index.css";
import "../styles/site-header.css";
import "../styles/blog.css";
import cangjieIcon from "../assets/cangjie-icon.png";
import SiteHeader from "../components/SiteHeader.astro";
import HeroParallax from "../components/HeroParallax.astro";

interface Props {
    title: string;
    description?: string;
    isBlogPage?: boolean;
}

const {
    title,
    description = "The Cangjie Programming Language UK Team – tutorials, projects, and practical resources for developers exploring the Cangjie programming language.",
    isBlogPage = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>
        <link rel="icon" href={cangjieIcon.src} type="image/png" />
        <meta name="description" content={description} />
        <meta name="theme-color" content="#20b2aa" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:type" content="website" />
        <meta property="og:url" content="https://cangjie-uk-team.example/" />
        <meta
            property="og:image"
            content="/QRCodes/CangjieOfficialWesbite.png"
        />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <link
            rel="stylesheet"
            href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css"
        />
    </head>
    <body>
        <SiteHeader />

        <slot />
        <HeroParallax />
    </body>
</html>
