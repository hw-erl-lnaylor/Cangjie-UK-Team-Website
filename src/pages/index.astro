---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BlogPostList from "../components/BlogPostList.astro";
import youtubeIcon from "../assets/youtube.png";
import twitterIcon from "../assets/twitter.png";
import linkedInIcon from "../assets/linkedin.png";
import gitcodeIcon from "../assets/gitcode.png";
import discordQr from "../assets/discord-qr.png";

const blogEntries: CollectionEntry<"blog">[] = await getCollection("blog");
const newsEntries: CollectionEntry<"news">[] = await getCollection("news");

const parseDmyDate = (dmy: string) => {
    const [day, month, year] = dmy.split("/");
    return new Date(Number(year), Number(month) - 1, Number(day));
};

const formatDateForDisplay = (dmy: string) =>
    new Intl.DateTimeFormat("en-GB", {
        year: "numeric",
        month: "short",
        day: "2-digit",
    }).format(parseDmyDate(dmy));

const sortedNewsEntries = newsEntries.sort((a, b) => {
    return (
        parseDmyDate(b.data.date).getTime() -
        parseDmyDate(a.data.date).getTime()
    );
});

const allTags = Array.from(
    new Set(blogEntries.flatMap((entry) => entry.data.tags || [])),
).sort((a, b) => a.localeCompare(b));
const homeBlogFilterKey = "home-blog-filter";
const counterApiWorkspace =
    import.meta.env.PUBLIC_COUNTERAPI_WORKSPACE || "cjpluk";
const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string) => {
    if (path === "/") return baseUrl;
    return `${baseUrl}${path.replace(/^\//, "")}`;
};
---

<Layout title="The Cangjie Programming Language UK Team">
    <div class="container">
        <header class="hero-section">
            <h1 class="main-title">The Cangjie Programming Language UK Team</h1>
            <p class="subtitle" aria-label="Site tagline">
                Building and empowering the ecosystem of the Cangjie
                programming language in the UK
            </p>
        </header>

        <main class="content">
            <div class="main-layout">
                <section class="projects-section" id="projects">
                    <div class="section-header">
                        <h2>Blog Posts</h2>
                    </div>
                    <div class="tag-chips" aria-label="Blog tags">
                        {
                            allTags.map((tag) => (
                                <button
                                    type="button"
                                    class="tag"
                                    data-blog-tag-chip
                                    data-filter-key={homeBlogFilterKey}
                                    data-tag={tag}
                                    aria-pressed="false"
                                >
                                    {tag}
                                </button>
                            ))
                        }
                    </div>
                    <BlogPostList
                        tags={[]}
                        interactiveFilterKey={homeBlogFilterKey}
                    />
                </section>

                <aside class="sidebar-column" aria-label="Sidebar">
                    <section class="sidebar-card news-card">
                        <h3>News</h3>
                        <div class="news-list" aria-label="News">
                            {
                                sortedNewsEntries
                                    .slice(0, 4)
                                    .map((entry, index) => (
                                        <a
                                            href={withBase(`/news/${index}`)}
                                            class="news-item"
                                        >
                                            <span class="news-item-title">
                                                {entry.data.title}
                                            </span>
                                            <span class="news-item-date">
                                                {formatDateForDisplay(
                                                    entry.data.date,
                                                )}
                                            </span>
                                        </a>
                                    ))
                            }
                        </div>
                    </section>

                    <section class="sidebar-card resources-card">
                        <h3>Main Project Resources</h3>
                        <p class="resources-intro">
                            Useful links for the Cangjie programming language
                            project:
                        </p>
                        <ul class="partners-list">
                            <li>
                                <a
                                    href="https://cangjie-lang.cn/en/download"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                >
                                    SDK download
                                    <span aria-hidden="true">↗</span>
                                </a>
                            </li>
                            <li>
                                <a
                                    href="https://cangjie-lang.cn/en/docs"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                >
                                    Docs
                                    <span aria-hidden="true">↗</span>
                                </a>
                            </li>
                            <li>
                                <a
                                    href="https://gitcode.com/Cangjie"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                >
                                    Source
                                    <span aria-hidden="true">↗</span>
                                </a>
                            </li>
                        </ul>
                    </section>

                    <section class="sidebar-card visit-card" aria-label="Total visits">
                        <h3>Total Visits</h3>
                        <p id="total-visits" class="visit-value">...</p>
                    </section>

                    <a
                        class="sidebar-card tech-talk-card"
                        href="https://www.youtube.com/watch?v=_pKV0zqoeZQ&feature=youtu.be"
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        <div class="tech-talk-thumb">
                            <img
                                src="https://img.youtube.com/vi/_pKV0zqoeZQ/hqdefault.jpg"
                                alt="YouTube cover for featured tech talk"
                                loading="lazy"
                            />
                            <div class="tech-talk-badge">Tech Talk</div>
                        </div>
                        <div class="tech-talk-meta">
                            <h3>Featured tech talk</h3>
                            <p class="tech-talk-title">
                                Expressive structured control with effect
                                handlers by Prof. Dan R. Ghica
                            </p>
                        </div>
                    </a>

                    <section class="sidebar-card partners-card">
                        <h3>Partners</h3>
                        <ul class="partners-list">
                            <li>
                                <a
                                    href="https://www.eclipse.org/"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    >Eclipse Foundation</a
                                >
                            </li>
                            <li>
                                <a
                                    href="https://www.openharmony.cn/homepage/"
                                    target="_blank"
                                    rel="noopener noreferrer">OpenHarmony</a
                                >
                            </li>
                        </ul>
                    </section>

                    <section class="sidebar-card discord-card">
                        <h3>Join our Discord</h3>
                        <img
                            class="discord-qr"
                            src={discordQr.src}
                            alt="Scan to join our Discord server"
                            loading="lazy"
                        />
                    </section>

                    <section class="sidebar-card follow-us-card" id="about">
                        <h3>Follow us</h3>
                        <nav class="social-links" aria-label="Official links">
                            <a
                                class="social-link"
                                href="https://www.youtube.com/@Cangjie-Lang"
                                target="_blank"
                                rel="noopener noreferrer"
                            >
                                <img
                                    class="social-icon-img"
                                    src={youtubeIcon.src}
                                    alt=""
                                />
                                <span class="social-label">YouTube</span>
                            </a>
                            <a
                                class="social-link"
                                href="https://x.com/Cangjie_Lang"
                                target="_blank"
                                rel="noopener noreferrer"
                            >
                                <img
                                    class="social-icon-img"
                                    src={twitterIcon.src}
                                    alt=""
                                />
                                <span class="social-label">X (Twitter)</span>
                            </a>
                            <a
                                class="social-link"
                                href="https://www.linkedin.com/company/cangjie/"
                                target="_blank"
                                rel="noopener noreferrer"
                            >
                                <img
                                    class="social-icon-img"
                                    src={linkedInIcon.src}
                                    alt=""
                                />
                                <span class="social-label">LinkedIn</span>
                            </a>
                            <a
                                class="social-link"
                                href="https://gitcode.com/Cangjie/cangjie_docs"
                                target="_blank"
                                rel="noopener noreferrer"
                            >
                                <img
                                    class="social-icon-img"
                                    src={gitcodeIcon.src}
                                    alt=""
                                />
                                <span class="social-label">GitCode</span>
                            </a>
                        </nav>
                    </section>
                </aside>
            </div>
        </main>
    </div>
    <script is:inline define:vars={{ counterApiWorkspace }}>
        (() => {
            const el = document.getElementById("total-visits");
            if (!el) return;

            const namespace = "cangjie-programming-language-uk-team";
            const key = "home-total-visits";
            const lastCountDateKey = "visit-last-count-date";
            const localCountKey = "home-total-visits-fallback";
            const lastRemoteValueKey = "home-total-visits-last-remote";
            const today = new Date().toISOString().slice(0, 10);

            const parseCounterApiValue = (payload) => {
                const data = payload?.data;
                if (!data) throw new Error("invalid counterapi response");

                if (typeof data.count === "number") return data.count;
                if (
                    typeof data.up_count === "number" &&
                    typeof data.down_count === "number"
                ) {
                    return data.up_count - data.down_count;
                }
                if (typeof data.up_count === "number") return data.up_count;
                throw new Error("counterapi response missing numeric count");
            };

            const setLastRemoteValue = (value) => {
                try {
                    window.localStorage.setItem(lastRemoteValueKey, String(value));
                } catch {
                    // ignore storage write errors
                }
            };

            const requestCounterApi = async (action) => {
                if (!counterApiWorkspace) {
                    throw new Error("counterapi workspace not configured");
                }

                if (action === "hit") {
                    const upUrl = `https://api.counterapi.dev/v2/${counterApiWorkspace}/${key}/up?ts=${Date.now()}`;
                    const upRes = await fetch(upUrl, { cache: "no-store" });
                    if (!upRes.ok) throw new Error("counterapi request failed");
                    const upPayload = await upRes.json();
                    parseCounterApiValue(upPayload);
                }

                const getUrl = `https://api.counterapi.dev/v2/${counterApiWorkspace}/${key}?ts=${Date.now()}`;
                const getRes = await fetch(getUrl, { cache: "no-store" });
                if (!getRes.ok) throw new Error("counterapi request failed");
                const getPayload = await getRes.json();
                return parseCounterApiValue(getPayload);
            };

            const requestCounterApiV1 = async (action) => {
                if (action === "hit") {
                    const upUrl = `https://api.counterapi.dev/v1/${namespace}/${key}/up?ts=${Date.now()}`;
                    const upRes = await fetch(upUrl, { cache: "no-store" });
                    if (!upRes.ok) throw new Error("counterapi v1 request failed");
                    const upData = await upRes.json();
                    if (!upData || typeof upData.count !== "number") {
                        throw new Error("invalid counterapi v1 response");
                    }
                }

                const getUrl = `https://api.counterapi.dev/v1/${namespace}/${key}?ts=${Date.now()}`;
                const getRes = await fetch(getUrl, { cache: "no-store" });
                if (!getRes.ok) throw new Error("counterapi v1 request failed");
                const getData = await getRes.json();
                if (!getData || typeof getData.count !== "number") {
                    throw new Error("invalid counterapi v1 response");
                }
                return getData.count;
            };

            const getLocalFallback = (increment) => {
                let current = 0;
                try {
                    current = Number(window.localStorage.getItem(localCountKey) || "0");
                    if (!Number.isFinite(current)) current = 0;
                    if (increment) {
                        current += 1;
                        window.localStorage.setItem(localCountKey, String(current));
                        window.localStorage.setItem(lastCountDateKey, today);
                    }
                } catch {
                    if (increment) current += 1;
                }
                return current;
            };

            (async () => {
                const lastCountDate = window.localStorage.getItem(lastCountDateKey) || "";
                const shouldIncrement = lastCountDate !== today;
                const action = shouldIncrement ? "hit" : "get";

                try {
                    const value = await requestCounterApi(action);
                    if (shouldIncrement) {
                        window.localStorage.setItem(lastCountDateKey, today);
                    }
                    setLastRemoteValue(value);
                    el.textContent = value.toLocaleString("en-GB");
                    return;
                } catch {
                    // Fall through to CounterAPI v1 fallback.
                }

                try {
                    const value = await requestCounterApiV1(action);
                    if (shouldIncrement) {
                        window.localStorage.setItem(lastCountDateKey, today);
                    }
                    setLastRemoteValue(value);
                    el.textContent = value.toLocaleString("en-GB");
                    return;
                } catch {
                    // Fall through to local fallback.
                }

                const fallbackValue = getLocalFallback(shouldIncrement);
                const lastRemoteValue = Number(
                    window.localStorage.getItem(lastRemoteValueKey) || "",
                );
                if (Number.isFinite(lastRemoteValue) && lastRemoteValue > 0) {
                    el.textContent = lastRemoteValue.toLocaleString("en-GB");
                    return;
                }
                el.textContent = fallbackValue.toLocaleString("en-GB");
            })();
        })();
    </script>
    <script is:inline define:vars={{ homeBlogFilterKey }}>
        (() => {
            const chips = Array.from(
                document.querySelectorAll(
                    `[data-blog-tag-chip][data-filter-key="${homeBlogFilterKey}"]`,
                ),
            );
            if (chips.length === 0) return;

            const selectedTags = new Set();

            function publish() {
                window.dispatchEvent(
                    new CustomEvent("blog-tag-filter-change", {
                        detail: {
                            key: homeBlogFilterKey,
                            tags: Array.from(selectedTags),
                        },
                    }),
                );
            }

            for (const chip of chips) {
                chip.addEventListener("click", () => {
                    const tag = chip.getAttribute("data-tag") || "";
                    if (!tag) return;

                    if (selectedTags.has(tag)) {
                        selectedTags.delete(tag);
                        chip.classList.remove("active");
                        chip.setAttribute("aria-pressed", "false");
                    } else {
                        selectedTags.add(tag);
                        chip.classList.add("active");
                        chip.setAttribute("aria-pressed", "true");
                    }

                    publish();
                });
            }

            publish();
        })();
    </script>
</Layout>
