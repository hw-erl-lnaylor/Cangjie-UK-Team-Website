---
import Layout from "../layouts/Layout.astro";
const baseUrl = import.meta.env.BASE_URL;
---

<Layout
    title="About — The Cangjie Programming Language UK Team"
    description="About The Cangjie Programming Language UK Team – who we are and what we do."
>
    <main class="container about-page">
        <div class="about-inner">
            <h1>About The Cangjie Programming Language UK Team</h1>
            <p class="lead">
                We are a team based in the Edinburgh focused on the <a
                    href="https://cangjie-lang.cn/en"
                    target="_blank"
                    rel="noopener noreferrer">Cangjie</a
                > programming language — also known as <strong>the Cangjie
                    programming language</strong> — sharing tutorials, writing
                blogs, and building practical resources for developers.
            </p>

            <section class="card">
                <h2>Who we are</h2>
                <p>
                    The Cangjie Programming Language UK Team brings together
                    developers and researchers
                    interested in high-performance, type-safe systems
                    programming with the Cangjie programming language. We
                    create learning materials, open-source projects, and
                    community content to help others get started and go deeper.
                </p>
            </section>

            <section class="card">
                <h2>What we do</h2>
                <p>
                    We maintain this site with <strong>Blogs</strong> (project write-ups
                    and technical posts), <strong>News</strong> (releases and updates),
                    and links to the official tutorial and channels for the
                    Cangjie programming language. You can follow our work here
                    and through the official community for the Cangjie
                    programming language.
                </p>
            </section>

            <section class="card">
                <h2>Get in touch</h2>
                <p>
                    For the language itself, visit the <a
                        href="https://cangjie-lang.cn/en"
                        target="_blank"
                        rel="noopener noreferrer">official website for the
                        Cangjie programming language</a
                    >. For tutorials and docs, check the links on our <a
                        href={baseUrl}>homepage</a
                    >. More contact and channel links are listed in the sidebar
                    there.
                </p>
            </section>
        </div>
    </main>
</Layout>

<style>
    .about-page {
        padding: 2rem 0 4rem;
    }
    .about-inner {
        max-width: 680px;
        margin: 0 auto;
        padding: 0 2rem;
    }
    .about-page h1 {
        font-size: 2rem;
        color: #0f4c4a;
        margin-bottom: 1.5rem;
    }
    .about-page .lead {
        font-size: 1.1rem;
        line-height: 1.7;
        color: #2c3e50;
        margin-bottom: 2rem;
    }
    .about-page .card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
        border: 1px solid #e5f0ef;
        padding: 2rem;
        margin-bottom: 2rem;
    }
    .about-page h2 {
        font-size: 1.25rem;
        color: #0f766e;
        margin-bottom: 0.75rem;
    }
    .about-page p {
        margin-bottom: 1rem;
        line-height: 1.7;
        color: #2c3e50;
    }
    .about-page p:last-child {
        margin-bottom: 0;
    }
</style>
