---
import cangjieLogo from "../assets/cangjie-logo.png";

const navItems = [
    { label: "Home", href: "/" },
    { label: "Blog", href: "/blog" },
    { label: "Learn", href: "/learn/learn.html" },
    { label: "Effect Handlers", href: "/effectHandlersIntro" },
    { label: "Distributed Actors", href: "/distributed-actors" },
    { label: "About", href: "/about" },
];

const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string) => {
    if (path === "/") return baseUrl;
    return `${baseUrl}${path.replace(/^\//, "")}`;
};

const normalizePath = (path: string) => {
    const trimmed = path.replace(/\/+$/, "");
    return trimmed === "" ? "/" : trimmed;
};

const currentPathFull = normalizePath(Astro.url.pathname);
const basePath = normalizePath(baseUrl);
const currentPath =
    basePath !== "/" && currentPathFull.startsWith(basePath)
        ? normalizePath(currentPathFull.slice(basePath.length) || "/")
        : currentPathFull;

const isActive = (href: string) => {
    const target = normalizePath(href);

    if (target === "/") return currentPath === "/";
    if (target === "/blog")
        return currentPath === "/blog" || currentPath.startsWith("/blog/");
    if (target === "/learn/learn.html")
        return (
            currentPath === "/learn/learn.html" ||
            currentPath.startsWith("/learn/")
        );
    return currentPath === target || currentPath.startsWith(`${target}/`);
};
---

<header class="site-header">
    <div class="site-header-inner">
        <a href={withBase("/")} class="brand brand-link">
            Cangjie UK
            <span class="brand-mark">
                <img
                    class="brand-logo"
                    src={cangjieLogo.src}
                    alt="Cangjie Logo"
                    loading="lazy"
                />
            </span>
        </a>
        <nav class="site-nav site-nav-desktop" aria-label="Primary">
            {
                navItems.map((item) => (
                    <a
                        href={withBase(item.href)}
                        class={`nav-link ${isActive(item.href) ? "active" : ""}`}
                    >
                        {item.label}
                    </a>
                ))
            }
        </nav>
        <details class="site-nav-menu site-nav-mobile">
            <summary class="site-nav-toggle" aria-label="Toggle navigation">
                Menu
            </summary>
            <nav class="site-nav" aria-label="Primary">
                {
                    navItems.map((item) => (
                        <a
                            href={withBase(item.href)}
                            class={`nav-link ${isActive(item.href) ? "active" : ""}`}
                        >
                            {item.label}
                        </a>
                    ))
                }
            </nav>
        </details>
    </div>
</header>
